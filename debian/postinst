#!/bin/sh
set -e

case "$1" in
    configure)
	install -d -m 0755 -o root -g root /etc/persoc/conf.d
	install -d -m 0750 -o root -g root /var/log/persoc/
	install -d -m 0755 -o root -g root /etc/logrotate.d

	if [ ! -e /etc/persoc/persoc.dab ] && [ -e /etc/persoc/persoc.dab.dpkg-new ]; then
		mv /etc/persoc/persoc.dab.dpkg-new /etc/persoc/persoc.dab
	fi
	if [ -e /etc/persoc/persoc.dab ]; then
		chown root:root /etc/persoc/persoc.dab
		chmod 0644 /etc/persoc/persoc.dab
	fi

	if [ ! -e /etc/logrotate.d/persoc ] && [ -e /etc/logrotate.d/persoc.dpkg-new ]; then
		mv /etc/logrotate.d/persoc.dpkg-new /etc/logrotate.d/persoc
	fi
	if [ -e /etc/logrotate.d/persoc ]; then
		chown root:root /etc/logrotate.d/persoc
		chmod 0644 /etc/logrotate.d/persoc
	fi
	if [ ! -e /var/log/persoc/persoc.log ]; then
		: > /var/log/persoc/persoc.log
	fi
	chown root:root /var/log/persoc/persoc.log
	chmod 0640 /var/log/persoc/persoc.log

	install -d -m 0700 -o root -g root /root/.ssh
	if [ ! -e /root/.ssh/ihk ] && command -v ssh-keygen >/dev/null 2>&1; then
		ssh-keygen -q -t ed25519 -N "" -f /root/.ssh/ihk -C "persoc@$(hostname 2>/dev/null || echo unknown)"
	fi
	if [ -e /root/.ssh/ihk ]; then
		chown root:root /root/.ssh/ihk
		chmod 0600 /root/.ssh/ihk
	fi
	if [ -e /root/.ssh/ihk.pub ]; then
		chown root:root /root/.ssh/ihk.pub
		chmod 0644 /root/.ssh/ihk.pub
		cp /root/.ssh/ihk.pub /etc/persoc/ihk.pub
		chown root:root /etc/persoc/ihk.pub
		chmod 0644 /etc/persoc/ihk.pub
	fi

	if [ ! -e /etc/persoc/deadlist.csv ]; then
		: > /etc/persoc/deadlist.csv
	fi
	chown root:root /etc/persoc/deadlist.csv
	chmod 0644 /etc/persoc/deadlist.csv
	;;
esac

#DEBHELPER#

exit 0
